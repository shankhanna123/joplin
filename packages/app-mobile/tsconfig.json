{
	"extends": "../../tsconfig.json",
	"include": [
		"**/*.ts",
		"**/*.tsx",
	],
	"exclude": [
		//Files that don't need transpilation
		"**/node_modules",
		"gulpfile.ts",
		"tools/*.ts",
	],
	"compilerOptions": {
		"types": ["jest", "@types/node"],
		"moduleSuffixes": [".ios", ".android", ".native", ""],
		"jsx": "react-jsx",
		"jsxImportSource": "react",
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"skipLibCheck": true
	}
}
